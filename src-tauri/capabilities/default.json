{
  "$schema": "../gen/schemas/desktop-schema.json",
  "identifier": "default",
  "description": "Capability for the main and settings windows",
  "windows": ["main", "settings"],
  "permissions": [
    "core:default",
    "core:window:allow-show",
    "opener:default",
    "dialog:allow-open",
    "dialog:allow-save",
    "window-state:default"
  ]
}
